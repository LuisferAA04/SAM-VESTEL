# CONFIGURACIÓN AGENTE SAM - VESTEL (plantilla)
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env a control de versiones.

# API Key de OpenAI
OPENAI_API_KEY=sk-...

# Modelo de OpenAI a usar
OPENAI_MODEL=gpt-4o

# Configuración del servidor
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
# IMPORTANTE: deja FLASK_DEBUG en False en producción (True habilita ejecución remota de código)
FLASK_DEBUG=False

# URL pública del servicio (necesaria para validar la firma de los webhooks de Twilio)
PUBLIC_BASE_URL=https://tu-dominio.com

# Base de datos
DATABASE_PATH=data/sam_database.db

# Modo pruebas: true = NO reconoce números recurrentes (siempre pide cédula).
# En producción ponlo en false para que recuerde al cliente y lo salude por su nombre.
MODO_PRUEBAS=false

# Fuente de usuarios/clientes: 'sqlite' (datos de prueba) o 'sheets' (Google Sheets)
USERS_SOURCE=sqlite
# Google Sheets (modo link público / CSV). La hoja debe estar compartida como
# "Cualquiera con el enlace -> Lector".
GOOGLE_SHEET_ID=
GOOGLE_SHEET_GID=0
GOOGLE_SHEET_CACHE_TTL=60

# Telegram (Alertas a grupo de sistemas)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Token secreto que configuras al registrar el webhook (setWebhook?secret_token=...)
TELEGRAM_WEBHOOK_SECRET=

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Empresa
EMPRESA_NOMBRE=Vestel
EMPRESA_SLOGAN=
